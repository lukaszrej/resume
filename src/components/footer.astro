---
import { PROFILE_INFO } from "@/lib/constants/profile";
const year = new Date().getFullYear();
---

<footer class="pt-8 pb-12">
  <div class="screen-line-before relative h-px w-full flex-shrink-0"></div>
  <div class="flex items-center justify-between pt-5">
    <span class="font-jet text-xs tracking-[0.04em] text-muted-foreground">
      {year}
    </span>
    <a
      href={`mailto:${PROFILE_INFO.email}`}
      class="font-jet text-xs text-muted-foreground no-underline"
    >
      {PROFILE_INFO.email}
    </a>
  </div>
</footer>
