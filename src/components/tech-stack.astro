---
import SectionTitle from "@/components/ui/section-title.astro";
import { TECH_STACK } from "@/lib/constants/tech-stack";
---

<section>
  <SectionTitle title="Tech Stack" n={2} />
  <div class="grid grid-cols-[repeat(auto-fill,minmax(80px,1fr))] gap-1.5 pt-5 pb-2">
    {TECH_STACK.map(item => (
      <div
        title={item.title}
        class="badge-hover flex flex-col items-center gap-2 px-2 pt-3 pb-2.5 border rounded-[6px] cursor-default"
      >
        <span class="flex items-center justify-center size-[26px] flex-shrink-0">
          {item.icon && <item.icon className="size-[26px]" />}
        </span>
        <span class="text-[0.5625rem] text-muted-foreground text-center leading-[1.3] w-full overflow-hidden text-ellipsis whitespace-nowrap">
          {item.title}
        </span>
      </div>
    ))}
  </div>
</section>
