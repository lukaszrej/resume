---
import SectionTitle from "@/components/ui/section-title.astro";
import { TECH_STACK } from "@/lib/constants/tech-stack";
---

<section>
  <SectionTitle title="Tech Stack" />
  <div class="grid grid-cols-[repeat(auto-fill,minmax(84px,1fr))] gap-2 py-6">
    {TECH_STACK.map(item => (
      <a
        href={item.href}
        target="_blank"
        rel="noopener noreferrer"
        title={item.title}
        class="flex flex-col items-center gap-2 px-2 pt-3.5 pb-2.5 border rounded-lg hover:bg-secondary transition-colors"
      >
        <span class="flex items-center justify-center size-7 flex-shrink-0">
          {item.icon && <item.icon className="size-7" />}
        </span>
        <span class="text-[0.625rem] text-muted-foreground text-center leading-[1.3] w-full overflow-hidden text-ellipsis whitespace-nowrap">
          {item.title}
        </span>
      </a>
    ))}
  </div>
</section>
