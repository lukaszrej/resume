---
import { Moon, Sun } from "lucide-react";
---

<button
  id="theme-toggle"
  class="inline-flex items-center justify-center w-9 h-9 border rounded-lg text-foreground hover:bg-secondary transition-colors cursor-pointer"
  title="Toggle theme"
>
  <Sun className="h-[1.1rem] w-[1.1rem] block dark:hidden" />
  <Moon className="h-[1.1rem] w-[1.1rem] hidden dark:block" />
  <span class="sr-only">Toggle theme</span>
</button>
<script is:inline>
  const getThemePreference = () => {
    if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
      return localStorage.getItem("theme");
    }
    return window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light";
  };

  const setThemeAppearance = theme => {
    if (theme === "dark") {
      document.documentElement.classList.add("dark");
    } else {
      document.documentElement.classList.remove("dark");
    }
    localStorage.setItem("theme", theme);
  };

  const theme = getThemePreference();
  setThemeAppearance(theme);

  document.addEventListener("astro:page-load", () => {
    const toggleButton = document.getElementById("theme-toggle");

    const toggleMode = () => {
      const isDarkMode = document.documentElement.classList.contains("dark");
      const newTheme = isDarkMode ? "light" : "dark";
      setThemeAppearance(newTheme);
    };

    toggleButton?.addEventListener("click", toggleMode);
  });
</script>
