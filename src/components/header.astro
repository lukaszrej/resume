---
import Avatar from "@/components/ui/avatar.astro";
import DashedLine from "@/components/ui/dashed-line.astro";
import MarkdownRenderer from "@/components/ui/markdown-renderer.astro";
import { PROFILE_INFO } from "@/lib/constants/profile";
---

<section class="py-8 sm:pt-[48px] sm:pb-[40px]">
  <!-- Mobile layout -->
  <div class="sm:hidden">
    <div class="mb-6 flex items-center gap-4">
      <Avatar
        className="block !h-[72px] !w-[72px] rounded-[8px] border object-cover"
        size={72}
        priority
      />
      <div>
        <h1
          class="m-0 mb-[5px] text-[2rem] leading-none font-bold tracking-[-0.03em] text-foreground"
        >
          {PROFILE_INFO.displayName}<span class="cursor-blink">_</span>
        </h1>
        <p class="m-0 font-jet text-[0.75rem] text-muted-foreground">
          {PROFILE_INFO.role}
        </p>
      </div>
    </div>
    <div class="h-6"></div>
    <DashedLine />
    <div class="my-5 text-sm leading-7 [&_p]:m-0 [&_strong]:font-medium">
      <MarkdownRenderer content={PROFILE_INFO.about} />
    </div>
    <a
      href={`mailto:${PROFILE_INFO.email}`}
      class="inline-flex items-center gap-1.5 border-b pb-0.5 font-jet text-xs text-muted-foreground no-underline"
    >
      <svg
        width="12"
        height="12"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <rect x="2" y="4" width="20" height="16" rx="2"></rect>
        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
      </svg>
      {PROFILE_INFO.email}
    </a>
  </div>

  <!-- Desktop layout -->
  <div class="hidden items-start justify-between gap-8 sm:flex">
    <div class="min-w-0 flex-1">
      <h1
        class="m-0 mb-[10px] leading-[0.95] font-bold text-foreground"
        style="font-size: clamp(3rem, 8vw, 4.5rem); letter-spacing: -0.04em;"
      >
        {PROFILE_INFO.displayName}<span class="cursor-blink">_</span>
      </h1>
      <p
        class="m-0 font-jet text-[0.875rem] tracking-[0.02em] text-muted-foreground"
      >
        {PROFILE_INFO.role}
      </p>
      <div class="h-8"></div>
      <DashedLine />
      <div
        class="my-6 text-[0.9rem] leading-[1.8] [&_p]:m-0 [&_strong]:font-medium"
      >
        <MarkdownRenderer content={PROFILE_INFO.about} />
      </div>
      <a
        href={`mailto:${PROFILE_INFO.email}`}
        class="inline-flex items-center gap-1.5 border-b pb-0.5 font-jet text-[0.8125rem] text-muted-foreground no-underline"
      >
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
        {PROFILE_INFO.email}
      </a>
    </div>
    <Avatar
      className="block !h-[148px] !w-[148px] flex-shrink-0 rounded-[8px] border object-cover"
      size={148}
      priority
    />
  </div>
</section>
