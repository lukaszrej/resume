---
import Avatar from "@/components/ui/avatar.astro";
import DashedLine from "@/components/ui/dashed-line.astro";
import MarkdownRenderer from "@/components/ui/markdown-renderer.astro";
import { PROFILE_INFO } from "@/lib/constants/profile";
---

<section class="py-8 sm:pt-[52px] sm:pb-[40px]">

  <!-- Mobile layout: avatar + name row, then about -->
  <div class="sm:hidden">
    <div class="flex items-center gap-4 mb-5">
      <div class="flex-shrink-0">
        <Avatar className="!w-[72px] !h-[72px] rounded-[7px] object-cover block" size={72} priority />
      </div>
      <div>
        <h1 class="font-bold text-[1.875rem] tracking-[-0.03em] leading-none mb-1 m-0 text-foreground">
          {PROFILE_INFO.displayName}
        </h1>
        <p class="text-sm text-muted-foreground m-0">{PROFILE_INFO.role}</p>
      </div>
    </div>
    <DashedLine />
    <div class="text-sm leading-7 my-5 [&_p]:m-0 [&_strong]:font-medium">
      <MarkdownRenderer content={PROFILE_INFO.about} />
    </div>
    <a
      href={`mailto:${PROFILE_INFO.email}`}
      class="inline-flex items-center gap-1.5 font-jet text-xs text-muted-foreground no-underline border-b pb-px"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
      </svg>
      {PROFILE_INFO.email}
    </a>
  </div>

  <!-- Desktop layout: name/content left, avatar right -->
  <div class="hidden sm:flex justify-between items-start gap-8">
    <div class="flex-1 min-w-0">
      <h1 class="font-bold leading-none mb-2 m-0 text-foreground" style="font-size: clamp(2.75rem, 7vw, 4.25rem); letter-spacing: -0.035em;">
        {PROFILE_INFO.displayName}
      </h1>
      <p class="text-[0.9375rem] text-muted-foreground mb-8 m-0">{PROFILE_INFO.role}</p>
      <DashedLine />
      <div class="text-[0.9rem] leading-7 my-6 [&_p]:m-0 [&_strong]:font-medium">
        <MarkdownRenderer content={PROFILE_INFO.about} />
      </div>
      <a
        href={`mailto:${PROFILE_INFO.email}`}
        class="inline-flex items-center gap-1.5 font-jet text-[0.8125rem] text-muted-foreground no-underline border-b pb-px"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        {PROFILE_INFO.email}
      </a>
    </div>
    <div class="flex-shrink-0">
      <Avatar className="!w-[148px] !h-[148px] rounded-[7px] object-cover block" size={148} priority />
    </div>
  </div>

</section>
