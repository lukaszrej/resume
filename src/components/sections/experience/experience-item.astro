---
import type { Experience } from "@/lib/types";
import DashedLine from "@/components/ui/dashed-line.astro";
import Badge from "@/components/ui/badge.astro";

interface Props {
  experience: Experience;
  isLast: boolean;
  isEven: boolean;
}

const { experience, isLast, isEven } = Astro.props;
const pos = experience.positions[0];
---

<div class:list={["py-7", isEven && "bg-gradient-to-r from-transparent to-black/[0.03] dark:to-white/[0.05] -mr-[clamp(16px,4vw,24px)] pr-[clamp(16px,4vw,24px)]"]}>
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5 sm:gap-4 mb-1">
    <h3 class="font-bold text-[1.0625rem] tracking-[-0.01em] text-foreground m-0">
      {experience.company}
    </h3>
    <span class="font-jet text-xs text-muted-foreground whitespace-nowrap flex-shrink-0">
      {pos.year}
    </span>
  </div>
  <p class="text-sm font-medium text-foreground mb-2 m-0">{pos.title}</p>
  <p class="text-sm text-muted-foreground mb-3.5 leading-[1.65] m-0">{pos.description}</p>
  <div class="flex gap-1.5 flex-wrap">
    {pos.skills.map(skill => <Badge>{skill}</Badge>)}
  </div>
</div>
{!isLast && <DashedLine />}
