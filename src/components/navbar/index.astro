---
import ModeToggle from "@/components/mode-toggle.astro";
import { PROFILE_INFO } from "@/lib/constants/profile";
import LogoIcon from "../../assets/logo-icon.svg";

interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<nav
  class:list={[
    "screen-line-after sticky top-0 z-50 w-full bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60",
    className,
  ]}
>
  <div
    class="mx-auto flex max-w-3xl items-center justify-between px-4 py-1 md:border-x"
  >
    <a href="/resume" class="flex items-center gap-2">
      <span class="inline-flex items-center">
        <LogoIcon
          class="relative top-[1px] h-8 w-8 text-lime-700 dark:text-cyan-100"
        />
      </span>

      <h1 class="text-xl leading-none font-black font-bold">
        {PROFILE_INFO.logo}
      </h1>
    </a>

    <div class="flex items-center justify-center gap-4">
      <a
        href="resume/cv.pdf"
        download="Lukasz-Rej-CV.pdf"
        class="ml-auto rounded bg-cyan-900 px-4 py-2 text-cyan-100 transition-colors hover:bg-cyan-800"
      >
        Download PDF
      </a>
      <ModeToggle />
    </div>
  </div>
</nav>
